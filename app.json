{
  "expo": {
    "name": "Puppy Prep",
    "slug": "puppyprep",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "puppyprep",
    "icon": "./assets/images/app-icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "description": "From bump to bark — a personalised day-by-day care calendar for dog breeders. Answer 12 quick questions, get the complete whelping + neonatal + socialisation schedule tailored to your breed.",
    "primaryColor": "#2D4A32",
    "backgroundColor": "#F5EDE0",
    "splash": {
      "image": "./assets/images/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#F5EDE0"
    },
    "assetBundlePatterns": [
      "assets/images/*",
      "assets/fonts/*"
    ],
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/15273f8f-78fb-49cb-ac7d-1daf3ed0737a",
      "enabled": true,
      "fallbackToCacheTimeout": 0,
      "checkAutomatically": "ON_LOAD"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.puppyprep.app",
      "buildNumber": "1",
      "infoPlist": {
        "NSUserNotificationsUsageDescription": "Puppy Prep uses notifications to remind you of critical care tasks — deworming, feeding windows, vet visits — so you never miss one.",
        "ITSAppUsesNonExemptEncryption": false,
        "LSApplicationQueriesSchemes": ["tel", "maps"]
      }
    },
    "android": {
      "package": "com.puppyprep.app",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/app-icon.png",
        "backgroundColor": "#ED5E20"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "NOTIFICATIONS",
        "VIBRATE",
        "RECEIVE_BOOT_COMPLETED",
        "SCHEDULE_EXACT_ALARM"
      ],
      "blockedPermissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "CAMERA",
        "READ_CONTACTS"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro",
      "output": "single"
    },
    "plugins": [
      "expo-router",
      "@react-native-community/datetimepicker",
      "expo-font",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/app-icon.png",
          "color": "#2D4A32",
          "defaultChannel": "default"
        }
      ],
      "expo-web-browser",
      [
        "react-native-android-widget",
        {
          "widgets": [
            {
              "name": "TodayCalendar",
              "label": "Puppy Prep — Today",
              "description": "Today's tasks + full 6-week calendar. Takes up nearly the entire home screen.",
              "minWidth": "250dp",
              "minHeight": "420dp",
              "targetCellWidth": 4,
              "targetCellHeight": 5,
              "resizeMode": "horizontal|vertical",
              "previewImage": "./assets/images/app-icon.png",
              "updatePeriodMillis": 0
            }
          ]
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "15273f8f-78fb-49cb-ac7d-1daf3ed0737a"
      },
      "router": {}
    },
    "owner": "bboxfred"
  }
}
