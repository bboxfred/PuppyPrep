{
  "expo": {
    "name": "Puppy Prep",
    "slug": "puppycare-compass",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "puppycare",
    "icon": "./assets/images/app-icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,

    "description": "From bump to bark — a personalised day-by-day care calendar for dog breeders. Answer 12 quick questions, get the complete whelping + neonatal + socialisation schedule tailored to your breed.",
    "primaryColor": "#2D4A32",
    "backgroundColor": "#F5EDE0",

    "splash": {
      "image": "./assets/images/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#F5EDE0"
    },

    "assetBundlePatterns": [
      "assets/images/*",
      "assets/fonts/*"
    ],

    "runtimeVersion": {
      "policy": "appVersion"
    },

    "updates": {
      "//": "OTA updates via EAS Update. URL is generated by `eas update:configure`.",
      "url": "https://u.expo.dev/REPLACE_AFTER_EAS_INIT",
      "enabled": true,
      "fallbackToCacheTimeout": 0,
      "checkAutomatically": "ON_LOAD"
    },

    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.puppycarecompass.app",
      "buildNumber": "1",
      "infoPlist": {
        "NSUserNotificationsUsageDescription": "Puppy Prep uses notifications to remind you of critical care tasks — deworming, feeding windows, vet visits — so you never miss one.",
        "ITSAppUsesNonExemptEncryption": false,
        "LSApplicationQueriesSchemes": ["tel", "maps"]
      }
    },

    "android": {
      "package": "com.puppycarecompass.app",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/app-icon.png",
        "backgroundColor": "#ED5E20"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "NOTIFICATIONS",
        "VIBRATE",
        "RECEIVE_BOOT_COMPLETED",
        "SCHEDULE_EXACT_ALARM"
      ],
      "blockedPermissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "CAMERA",
        "READ_CONTACTS"
      ]
    },

    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro",
      "output": "single"
    },

    "plugins": [
      "expo-router",
      "@react-native-community/datetimepicker",
      "expo-font",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/app-icon.png",
          "color": "#2D4A32",
          "defaultChannel": "default"
        }
      ]
    ],

    "extra": {
      "//": "eas.projectId is injected automatically by `eas init`.",
      "eas": {
        "projectId": "REPLACE_AFTER_EAS_INIT"
      }
    },

    "owner": "REPLACE_WITH_YOUR_EXPO_USERNAME"
  }
}
